# Required API credentials (发现页 Last.fm / Spotify 用)
REACT_APP_LASTFM_API_KEY=
REACT_APP_SPOTIFY_CLIENT_ID=
REACT_APP_SPOTIFY_CLIENT_SECRET=

# TuneScout+ 后端(go-music-dl)地址。前后端同源部署时可留空。
REACT_APP_MUSICDL_API=http://127.0.0.1:8080

# Optional: set when hosting in a subdirectory
# REACT_APP_BASENAME=/tunescout
